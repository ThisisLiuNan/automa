{
  "compilerOptions": {
    "allowJs": false,
    "checkJs": false,
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"],
      "@business": ["business/dev/*"]
    },
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "strict": false
  },
  "include": ["src/**/*", "utils/**/*"]
}
